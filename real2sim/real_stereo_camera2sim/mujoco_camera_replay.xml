<mujoco model="orbslam3_camera_trajectory_replay">
  <compiler angle="radian" autolimits="true" />

  <option timestep="0.005" gravity="0 0 -9.81" />

  <extension>
    <plugin plugin="mujoco.sensor.ray_caster_camera" />
  </extension>

  <visual>
    <global azimuth="135" elevation="-25" offwidth="1280" offheight="720" />
    <quality shadowsize="2048" />
    <headlight diffuse="0.6 0.6 0.6" ambient="0.2 0.2 0.2" specular="0.1 0.1 0.1" />
  </visual>

  <include file="mujoco_custom_scene.xml" />

  <asset>
    <material name="camera_body" rgba="0.08 0.08 0.10 1" />
    <material name="axis_x" rgba="1.0 0.05 0.05 1" />
    <material name="axis_y" rgba="0.05 0.75 0.05 1" />
    <material name="axis_z" rgba="0.05 0.25 1.0 1" />
    <material name="path" rgba="0.0 0.35 1.0 1" />
  </asset>

  <worldbody>
    <body name="tracked_camera_mocap" mocap="true" pos="0 0 0.6" quat="1 0 0 0">
      <geom name="camera_box" type="box" size="0.055 0.035 0.025" material="camera_body" />

      <!-- Body axes follow the ORB/OpenCV camera convention: X right, Y down, Z forward. -->
      <geom name="camera_axis_x" type="capsule" fromto="0 0 0 0.18 0 0" size="0.006"
        material="axis_x" />
      <geom name="camera_axis_y" type="capsule" fromto="0 0 0 0 0.18 0" size="0.006"
        material="axis_y" />
      <geom name="camera_axis_z" type="capsule" fromto="0 0 0 0 0 0.24" size="0.006"
        material="axis_z" />

      <!-- MuJoCo cameras look along local -Z. This fixed 180 deg X rotation maps
           the camera view onto the ORB/OpenCV +Z optical axis. -->
      <camera name="tracked_camera" pos="0 0 0" quat="0 1 0 0"
        focal="1 1"
        sensorsize="2.0 1.1547005"
        resolution="640 370" />
    </body>

    <camera name="overview" pos="2.5 -3.0 2.0" xyaxes="0.76 0.65 0 -0.32 0.38 0.87" fovy="45" />
  </worldbody>

  <sensor>
    <plugin name="tracked_depth_raycaster" plugin="mujoco.sensor.ray_caster_camera"
      objtype="camera" objname="tracked_camera">
      <config key="focal_length" value="1" />
      <config key="horizontal_aperture" value="2" />
      <config key="vertical_aperture" value="1.154700538" />
      <config key="size" value="64 32" />
      <config key="dis_range" value="0.01 5.0" />
      <config key="baseline" value="0.095" />
      <config key="lossangle" value="80" />
      <config key="min_energy" value="0.2" />
      <config key="sensor_data_types" value="distance_to_image_plane_noise" />
      <config key="noise_type" value="stereo_noise" />
      <config key="noise_cfg" value="6 0" />
      <config key="draw_hip_point" value="1 0.015 1 0 0 0.75" />
      <config key="geomgroup" value="1 1 1 1 1 1" />
      <config key="detect_parentbody" value="0" />
      <config key="n_step_update" value="1" />
    </plugin>

    <plugin name="tracked_aux_depth_raycaster" plugin="mujoco.sensor.ray_caster_camera"
      objtype="camera" objname="tracked_camera">
      <config key="focal_length" value="1" />
      <config key="horizontal_aperture" value="2" />
      <config key="vertical_aperture" value="1.154700538" />
      <config key="size" value="64 32" />
      <config key="dis_range" value="0.01 5.0" />
      <config key="baseline" value="0.0" />
      <config key="lossangle" value="88" />
      <config key="min_energy" value="0.0" />
      <config key="sensor_data_types" value="distance_to_image_plane_noise" />
      <config key="noise_type" value="noise1" />
      <config key="noise_cfg" value="0 0 0.05 0" />
      <config key="geomgroup" value="1 1 1 1 1 1" />
      <config key="detect_parentbody" value="0" />
      <config key="n_step_update" value="1" />
    </plugin>
  </sensor>
</mujoco>
