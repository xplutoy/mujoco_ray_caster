<mujocoinclude>
  <asset>
    <!-- Put textures, materials, meshes, and other assets for your custom scene here. -->
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.86 0.86 0.86" rgb2="0.72 0.72 0.72"/>
    <material name="grid" texture="grid" texrepeat="16 16" reflectance="0.08"/>
    <material name="scene_wall" rgba="0.72 0.75 0.78 1"/>
    <material name="scene_marker" rgba="0.90 0.18 0.12 1"/>
  </asset>

  <worldbody>
    <!-- Put lights, geoms, bodies, and fixed cameras for your custom scene here. -->
    <light name="key" pos="2 -3 4" dir="-0.4 0.5 -1" directional="true"/>
    <geom name="ground" type="plane" size="8 8 0.02" material="grid"/>

    <!-- Example reference geometry; edit or delete freely. -->
    <geom name="reference_wall" type="box" pos="-0.3 0.85 0.3" 
    size="0.3 0.15 0.3" material="scene_wall"/>

    <geom type="cylinder" pos="0.3 0.85 0" size="0.01 1.5" material="scene_marker"/>
    
  </worldbody>
</mujocoinclude>
