<mujoco model="ray_caster_test">
  <include file="scene.xml" />
  <compiler autolimits="true" />
  <option timestep="0.002" />

  <extension>
    <plugin plugin="mujoco.sensor.ray_caster_camera" />
  </extension>
  <asset>
    <mesh file="bunny.obj" scale="1.5 1.5 1.5"/>
    <mesh name="big_bunny" file="bunny.obj" scale="5 5 5"/>
    <mesh name="soda_can" file="soda_can.obj" scale="0.001 0.001 0.001"/>
  </asset>

  <visual>
    <headlight ambient=".7 .7 .7" diffuse=".2 .2 .2" specular="0.1 0.1 0.1" />
    <map znear="0.01" />
  </visual>

  <worldbody>

    <body pos="-0.25 0 0.25"  euler="0 5 0" mocap="true">
      <geom type="box" size="0.08 0.2 0.1" rgba="0 1 1 0.2" />
      <camera name="RayCasterCamera" ipd="0.095" focal="1 1"
        sensorsize="1.6 1.1547005"
        resolution="4 4" xyaxes="0 -1 0 0 0 1" />
    </body>

    <geom type="box" pos="1.0 0 0" size="0.1 2 1" />
    <body pos="0.4 0 0.2"  mocap="true">
    <geom type="mesh" mesh="bunny" xyaxes="0 -1 0 0 0 1" rgba="0.8 0.2 0.1 1"/>
    </body>

    <body pos="0.4 -0.3 0.3"  mocap="true">
    <geom type="mesh" mesh="soda_can" rgba="0.9 0.1 0.1 1"/>
    </body>


    <geom type="mesh" mesh="big_bunny" pos="0.0 -2.0 0" xyaxes="-1 0 0 0 0 1" rgba="0.8 0.2 0.1 1"/>

  </worldbody>

  <sensor>

    <plugin name="raycastercamera" plugin="mujoco.sensor.ray_caster_camera" objtype="camera"
      objname="RayCasterCamera">
      <config key="focal_length" value="1" />
      <config key="horizontal_aperture" value="1.6" />
      <config key="vertical_aperture" value="1.154700538" />
      <config key="size" value="48 32" />
      <config key="dis_range" value="0.01 3" />

      <!-- <config key="compute_time_log" value="1" /> -->

      <!-- <config key="draw_deep_ray" value="1 5 1 1 0.2 0.5 1" /> -->
      <!-- <config key="draw_deep_ray_ids" value="0 10 1 0 0 0.5 1 2 3 4 5 30" />
      <config key="draw_deep" value="2 5 0 1 0" /> -->
      <config key="draw_hip_point" value="1 0.02" />

      <!-- <config key="draw_normal" value="1 5 " /> -->

      <config key="sensor_data_types" value="distance_to_image_plane distance_to_image_plane_noise" />
      <config key="noise_type" value="stereo_noise" />
      <config key="noise_cfg" value="4 0" />
      
      <config key="baseline" value="0.095" />
      <!-- <config key="num_thread" value="4" /> -->
      <config key="lossangle" value="75" />
      <config key="min_energy" value="0.2" />
    </plugin>


  </sensor>

</mujoco>